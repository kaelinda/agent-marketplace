{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenViking Memory",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "content",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique memory ID"
    },
    "type": {
      "type": "string",
      "enum": [
        "profile",
        "preference",
        "project",
        "environment",
        "case",
        "decision",
        "agent_reflection"
      ]
    },
    "scope": {
      "type": "string",
      "description": "viking:// namespace URI"
    },
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "content": {
      "type": "string",
      "maxLength": 5000
    },
    "summary": {
      "type": "string",
      "maxLength": 500
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "conversation",
            "manual",
            "commit",
            "import"
          ]
        },
        "session_id": {
          "type": "string"
        },
        "message_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "sensitive": {
          "type": "boolean"
        },
        "user_confirmed": {
          "type": "boolean"
        },
        "retention": {
          "type": "string",
          "enum": [
            "short_term",
            "long_term",
            "permanent"
          ]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "obsolete",
        "deleted",
        "archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}