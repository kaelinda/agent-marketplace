{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Doctor Check Result",
  "type": "object",
  "required": [
    "result",
    "checks"
  ],
  "properties": {
    "result": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL"
      ]
    },
    "meta": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "tenant": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail",
              "skip"
            ]
          },
          "detail": {
            "type": "string"
          },
          "elapsed": {
            "type": "integer"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}