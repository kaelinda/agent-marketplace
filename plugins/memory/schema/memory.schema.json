{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenViking Memory",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "content",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique memory ID"
    },
    "type": {
      "type": "string",
      "enum": [
        "profile",
        "preference",
        "project",
        "environment",
        "case",
        "decision",
        "agent_reflection"
      ]
    },
    "scope": {
      "type": "string",
      "description": "viking:// namespace URI"
    },
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "content": {
      "type": "string",
      "maxLength": 5000
    },
    "summary": {
      "type": "string",
      "maxLength": 500
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "conversation",
            "manual",
            "commit",
            "import"
          ]
        },
        "session_id": {
          "type": "string"
        },
        "message_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "sensitive": {
          "type": "boolean"
        },
        "user_confirmed": {
          "type": "boolean"
        },
        "retention": {
          "type": "string",
          "enum": [
            "short_term",
            "long_term",
            "permanent"
          ]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "obsolete",
        "deleted",
        "archived"
      ]
    },
    "owner_id": {
      "type": "string",
      "description": "Identity string of the writer (Phase 3). Format: '<entity_type>:<id>', e.g. 'agent:devbot' or 'user:alice'. Used by SharingManager.can_access to evaluate ownership."
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "team", "public"],
      "description": "Default 'private' (only owner can read). 'team' grants read to anyone in the same team_ids. 'public' grants read to anyone in the same tenant. Phase 3."
    },
    "shared_with": {
      "type": "array",
      "description": "Identity strings explicitly granted access (Phase 3). Each item is '<entity_type>:<id>', e.g. 'agent:devbot' / 'team:platform' / 'user:alice'.",
      "items": {
        "type": "string",
        "pattern": "^(user|agent|team):.+$"
      }
    },
    "shared_perms": {
      "type": "object",
      "description": "Optional per-target permission overrides (Phase 3). Key is the same identity string as shared_with; value is 'read' or 'write'. Identities not listed here default to 'read'.",
      "additionalProperties": {
        "type": "string",
        "enum": ["read", "write"]
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}